    take(quoteTermDates[1], size(bldQuotePrices[1])) join
    take(quoteTermDates[2], size(bldQuotePrices[2])) join
    take(quoteTermDates[3], size(bldQuotePrices[3]));
bldQuoteStrikesVec = bldQuoteStrikes[0] join bldQuoteStrikes[1] join
    bldQuoteStrikes[2] join bldQuoteStrikes[3];
bldQuotePayoffTypesVec = bldQuotePayoffTypes[0] join bldQuotePayoffTypes[1] join
    bldQuotePayoffTypes[2] join bldQuotePayoffTypes[3];
bldQuotePricesVec = bldQuotePrices[0] join bldQuotePrices[1] join
    bldQuotePrices[2] join bldQuotePrices[3];
idxOptionPrices = table(bldQuoteExpiriesVec as expiry,
    bldQuoteStrikesVec as strike,
    bldQuotePayoffTypesVec as optionType,
    bldQuotePricesVec as price);
ok = t("builder matrices loaded",
    size(bldCallPrices) == 4 && size(bldPutPrices) == 4 &&
    size(bldStrikes) == 4 && size(quotePrices) == 4 &&
    size(dailyObsDates) == 180);
testNum = testNum + 1;
passNum = passNum + iif(ok, 1, 0);

ok = t("index dividend option price table loaded",
    size(idxOptionPrices) == size(bldQuotePricesVec));
testNum = testNum + 1;
passNum = passNum + iif(ok, 1, 0);

emptyFuturePrices = array(DOUBLE, 0);
idxDivCurve = caplib::BuildEqIndexDividendCurve(
    asOfDate, quoteTermDates, emptyFuturePrices, idxOptionPrices,
    underlyingPrice, irCurve, "IDX_DIV_CURVE", true);
ok = t("BuildEqIndexDividendCurve -> [IDX_DIV_CURVE, json]",
    isHandleJson(idxDivCurve, "IDX_DIV_CURVE"));
testNum = testNum + 1;
passNum = passNum + iif(ok, 1, 0);

volSurfDefinition = caplib::CreateVolatilitySurfaceDefinition(
    "STRIKE_VOL_SMILE", "SVI_SMILE_METHOD",
    "FLAT_EXTRAP", "LINEAR_IN_VARIANCE", "FLAT_IN_VOLATILITY",
    "ACT_365_FIXED", "LOG_NORMAL_VOL_TYPE", "DELTA",
    -1.0e-5, 1.0e-5, "VOL_SURF_DEF", true);
ok = t("CreateVolatilitySurfaceDefinition -> [VOL_SURF_DEF, json]",
    isHandleJson(volSurfDefinition, "VOL_SURF_DEF"));
testNum = testNum + 1;
passNum = passNum + iif(ok, 1, 0);

volSurfBuildSettings = caplib::CreateVolSurfBuildSettings(1, 0.5, "VOL_SURF_BUILD_SETTINGS", true);
ok = t("CreateVolSurfBuildSettings -> [VOL_SURF_BUILD_SETTINGS, json]",
    isHandleJson(volSurfBuildSettings, "VOL_SURF_BUILD_SETTINGS"));
testNum = testNum + 1;
passNum = passNum + iif(ok, 1, 0);

eqOptionQuotes = caplib::CreateEqOptionQuoteMatrix(
    "EUROPEAN", "SPOT_UNDERLYING_TYPE", asOfDate,
    quoteTermDates, quotePayoffTypes, quotePrices, quoteStrikes,
    underlying, "EQ_OPTION_QUOTES", true);
ok = t("CreateEqOptionQuoteMatrix -> [EQ_OPTION_QUOTES, json]",
    isHandleJson(eqOptionQuotes, "EQ_OPTION_QUOTES"));
testNum = testNum + 1;
passNum = passNum + iif(ok, 1, 0);

volSurfaceHandle = "";
try {
    volSurface = caplib::BuildEqVolatilitySurface(
        asOfDate, underlying, volSurfDefinition[0], eqOptionQuotes[0],
        [underlyingPrice], irCurve, divCurve, volSurfBuildSettings[0],
        bsmAnalyticalSettings, "VOL_SURF", true);
    volSurfaceHandle = volSurface[0];
    ok = t("BuildEqVolatilitySurface -> [VOL_SURF, json]",
        isHandleJson(volSurface, "VOL_SURF"));
    testNum = testNum + 1;
    passNum = passNum + iif(ok, 1, 0);

    mktData = caplib::CreateEqMktDataSet(
        asOfDate, underlying, underlyingPrice,
        irCurve, divCurve, volSurfaceHandle,
        quantoIr, quantoFxVol, 0.0, "EQ_MKT", true);
    ok = t("CreateEqMktDataSet -> [EQ_MKT, json]",
        isHandleJson(mktData, "EQ_MKT"));
    testNum = testNum + 1;
    passNum = passNum + iif(ok, 1, 0);
} catch(ex) {
    print("  FAIL: EQ builder exception: " + ex);
    testNum = testNum + 1;
}

