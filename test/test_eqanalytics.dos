    [2.50, 2.55, 2.60, 2.65, 2.70, 2.75, 2.80, 2.85, 2.90, 2.95, 3.00, 3.10, 3.20, 3.30, 3.40, 3.50],
    [2.50, 2.55, 2.60, 2.65, 2.70, 2.75, 2.80, 2.85, 2.90, 2.95, 3.00, 3.10, 3.20, 3.30, 3.40]
];
bldQuotePrices = [
    bldCallPrices[0] join bldPutPrices[0],
    bldCallPrices[1] join bldPutPrices[1],
    bldCallPrices[2] join bldPutPrices[2],
    bldCallPrices[3] join bldPutPrices[3]
];
bldQuoteStrikes = [
    bldStrikes[0] join bldStrikes[0],
    bldStrikes[1] join bldStrikes[1],
    bldStrikes[2] join bldStrikes[2],
    bldStrikes[3] join bldStrikes[3]
];
bldQuotePayoffTypes = [
    take("CALL", size(bldCallPrices[0])) join take("PUT", size(bldPutPrices[0])),
    take("CALL", size(bldCallPrices[1])) join take("PUT", size(bldPutPrices[1])),
    take("CALL", size(bldCallPrices[2])) join take("PUT", size(bldPutPrices[2])),
    take("CALL", size(bldCallPrices[3])) join take("PUT", size(bldPutPrices[3]))
];
bldQuoteExpiriesVec =
