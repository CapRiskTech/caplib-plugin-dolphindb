ok = t("CreateCalendar -> FX calendars", calEutaCreated && calGbloCreated && calHkhkCreated);
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CreateFxSpotTemplate -> [EURUSD_SPOT_TPL, json]",
