testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CreateFxMktDataSet -> [EURUSD_MKT, json]", isHandleJson(eurusdMktData, "EURUSD_MKT"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CreateFxMktDataSet -> [USDCNH_MKT, json]", isHandleJson(usdcnhMktData, "USDCNH_MKT"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CreateFxMktDataSet empty vol -> [USDCNH_FALLBACK_MKT, json]",
    isHandleJson(usdcnhFallbackMktData, "USDCNH_FALLBACK_MKT") &&
    hasJsonField(usdcnhFallbackMktData[1], "vol_surf"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CalcFxForwardRate -> scalar", calcFxForwardRateValue > 0.0);
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CalcFxSwapPoint -> scalar", calcFxSwapPointValue > -1.0 && calcFxSwapPointValue < 1.0);
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CalcFxAtmStrike -> scalar", calcFxAtmStrikeValue > 0.0);
