dailyObsDates = 2020.02.22..2020.08.19;
dailyObsValues = take(0.0, size(dailyObsDates));
dailyObsWeights = take(1.0, size(dailyObsDates));
couponDates = [2020.03.23, 2020.04.22, 2020.05.22,
