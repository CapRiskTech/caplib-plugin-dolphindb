ok = t("CreatePhoenixAutoCallableNote -> CM_PH_INST", phoenixNote == "CM_PH_INST");
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);
phoenixPricingResult = caplib::PriceCmPhoenixAutoCallableNote(
    phoenixNote, asOfDate, mktData[0], bsmMcSettings, cmNoRisk[0], "", "", true);
ok = checkPricingResult("PriceCmPhoenixAutoCallableNote", phoenixPricingResult, "CM_PH_INST_results");
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

print("");
print("--- Test 16: SnowballAutoCallableNote (BSM MONTE_CARLO) ---");
snowballNote = caplib::CreateSnowballAutoCallableNote(
    0.12, 2020.02.21, couponDates, "ACT_365_FIXED",
