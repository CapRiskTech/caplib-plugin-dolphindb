    0.015, 0.0, 1, 1000000.0, currency, "FUTURE", currency, underlying, "CM_PP_INST",
    dailyObsDates, dailyObsValues, dailyObsWeights, false);
ok = t("CreatePingPongOption -> CM_PP_INST", pingPongOption == "CM_PP_INST");
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);
pingPongPricingResult = caplib::PriceCmPingPongOption(
