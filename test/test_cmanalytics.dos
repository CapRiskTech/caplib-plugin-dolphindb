// ============================================================================
// test_cmanalytics.dos
// Native DolphinDB CM Analytics tests.
// Assertions validate handles and PricingResults JSON fields instead of raw
// protobuf bytes, so the tests remain stable across protobuf serialization.
// ============================================================================

print("============================================");
print("  CM Analytics Test Suite                  ");
print("============================================");

