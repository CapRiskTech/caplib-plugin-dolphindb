couponObsValues = take(0.0, size(couponDates));
couponObsWeights = take(1.0, size(couponDates));

print("  Setup fixtures loaded");

// ============================================================================
// Helpers
// ============================================================================
testNum = 0;
passNum = 0;

def t(name, cond) {
    if (cond) { print("  PASS: " + name); }
    else      { print("  FAIL: " + name); }
    return cond;
}

def isHandleJson(result, expectedHandle) {
    return strpos(typestr(result), "STRING VECTOR") >= 0 &&
        size(result) == 2 && result[0] == expectedHandle && strlen(result[1]) > 0;
}

def hasJsonField(json, fieldName) {
    return strpos(json, "\"" + fieldName + "\"") >= 0;
}

def isPricingResultsJson(result, expectedHandle) {
    return isHandleJson(result, expectedHandle) &&
        hasJsonField(result[1], "present_value") &&
        hasJsonField(result[1], "cash_value") &&
        hasJsonField(result[1], "currency");
}

def checkPricingResult(name, result, expectedHandle) {
    return t(name + " -> [" + expectedHandle + ", PricingResults JSON fields]",
        isPricingResultsJson(result, expectedHandle));
}

ok = t("CreateCmRiskSettings -> [CM_RISK, json]", isHandleJson(cmRisk, "CM_RISK"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CreateCmRiskSettings -> [CM_NO_RISK, json]", isHandleJson(cmNoRisk, "CM_NO_RISK"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

// ============================================================================
// Test 1: CM volatility surface builder
// ============================================================================
print("");
print("--- Test 1: CM volatility surface builder ---");

volSurfDefinition = caplib::CreateVolatilitySurfaceDefinition(
    "STRIKE_VOL_SMILE", "SVI_SMILE_METHOD",
    "FLAT_EXTRAP", "LINEAR_IN_VARIANCE", "FLAT_IN_VOLATILITY",
    "ACT_365_FIXED", "LOG_NORMAL_VOL_TYPE", "DELTA",
    -1.0e-5, 1.0e-5, "CM_VOL_SURF_DEF", true);
ok = t("CreateVolatilitySurfaceDefinition -> [CM_VOL_SURF_DEF, json]",
    isHandleJson(volSurfDefinition, "CM_VOL_SURF_DEF"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

volSurfBuildSettings = caplib::CreateVolSurfBuildSettings(1, 0.5, "CM_VOL_BUILD_SETTINGS", true);
ok = t("CreateVolSurfBuildSettings -> [CM_VOL_BUILD_SETTINGS, json]",
    isHandleJson(volSurfBuildSettings, "CM_VOL_BUILD_SETTINGS"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

cmOptionQuotes = caplib::CreateCmOptionQuoteMatrix(
    "AMERICAN", "FUTURE_UNDERLYING_TYPE", asOfDate,
    termDates, payoffTypes, strikes, prices, underlying, "CM_OPTION_QUOTES", true);
ok = t("CreateCmOptionQuoteMatrix -> [CM_OPTION_QUOTES, json]",
    isHandleJson(cmOptionQuotes, "CM_OPTION_QUOTES") &&
    hasJsonField(cmOptionQuotes[1], "quote_smiles"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

volSurface = caplib::BuildCmVolatilitySurface(
    asOfDate, underlying, volSurfDefinition[0], cmOptionQuotes[0],
    underlyingPrices, irCurve, fwdCurve, volSurfBuildSettings[0], "CM_VOL_SURF", true);
ok = t("BuildCmVolatilitySurface -> [CM_VOL_SURF, json]",
    isHandleJson(volSurface, "CM_VOL_SURF") &&
    hasJsonField(volSurface[1], "vol_smiles"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

// Explicit zero-rate quanto curves are supplied even with zero correlation.
quantoDates = [2020.02.22, 2030.02.24];
quantoValues = [0.0, 0.0];
quantoIr = caplib::CreateIrYieldCurve(
    asOfDate, quantoDates, quantoValues,
    "ZERO_RATE", "ACT_365_FIXED", "LINEAR_INTERP", "FLAT_EXTRAP",
    "CONTINUOUS_COMPOUNDING", "USD", "USD_FLAT_ZERO", "QUANTO_IR", false);
quantoFxVol = caplib::CreateVolatilityCurve(
    asOfDate, quantoDates, quantoValues,
    "ACT_365_FIXED", "LINEAR_INTERP", "FLAT_EXTRAP",
    underlying, "QUANTO_FX_VOL", false);

mktData = caplib::CreateCmMktDataSet(
    asOfDate, underlying, underlyingPrice,
    irCurve, fwdCurve, volSurface[0],
    quantoIr, quantoFxVol, 0.0, "CM_MKT", true);
ok = t("CreateCmMktDataSet -> [CM_MKT, json]", isHandleJson(mktData, "CM_MKT"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

