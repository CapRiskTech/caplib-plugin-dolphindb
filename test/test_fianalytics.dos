    hasJsonField(fiRisk[1], "ir_curve_settings") &&
    hasJsonField(fiRisk[1], "cs_curve_settings") &&
    hasJsonField(fiRisk[1], "theta_settings"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CreateVanillaBondRiskSettings -> [FI_VANILLA_BOND_RISK, json]",
    isHandleJson(vanillaBondRisk, "FI_VANILLA_BOND_RISK") &&
    hasJsonField(vanillaBondRisk[1], "theta_settings"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

print("");
print("--- Test 4: FI scalar calculators ---");
conversionFactor = caplib::CalcConversionFactor(
    0.03, "ANNUAL", 0.03, 2025.07.22, asOfDate, 2021.07.22);
ok = t("CalcConversionFactor -> positive double", conversionFactor > 0.0);
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

impliedRepoRate = caplib::CalcImpliedRepoRate(
    98.0, 1.0, 99.0, 0.03, asOfDate, 2021.07.22, 2021.09.22,
    "ACT_365", 2022.07.22, "ANNUAL");
ok = t("CalcImpliedRepoRate -> finite double", impliedRepoRate == impliedRepoRate);
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

yieldToMaturity = caplib::CalcYieldToMaturity(
    asOfDate, "DISCRETE_COMPOUNDING", vanillaBond, cnyTreasStdCfets[0], 972294.9381034705,
    "DIRTY_PRICE", "ANNUAL");
ok = t("CalcYieldToMaturity -> finite double", yieldToMaturity == yieldToMaturity);
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

fixedCpnBondParRate = caplib::CalcFixedCpnBondParRate(
    asOfDate, vanillaBond, cnyTreasStdCfets[0], "");
ok = t("CalcFixedCpnBondParRate -> finite double", fixedCpnBondParRate == fixedCpnBondParRate);
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

print("");
print("--- Test 5: VanillaBond pricing and greeks path ---");
vanillaBondPricingResult = caplib::PriceVanillaBond(
    vanillaBond, asOfDate, fiMktData[0], pricingSettings, fiRisk[0], "", "", true);
ok = t("PriceVanillaBond -> [FI_VANILLA_BOND_results, PricingResults JSON fields]",
    isPricingResultsJson(vanillaBondPricingResult, "FI_VANILLA_BOND_results"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("PriceVanillaBond greeks path -> sensitivity/cash-flow JSON present",
    hasJsonField(vanillaBondPricingResult[1], "sensitivity") ||
    hasJsonField(vanillaBondPricingResult[1], "cash_flow_results") ||
    hasJsonField(vanillaBondPricingResult[1], "specific_pricing_results"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

print("");
print("============================================");
print("  TEST RESULTS");
print("  Passed: " + string(passNum) + " / " + string(testNum));
print("  Failed: " + string(testNum - passNum) + " / " + string(testNum));
print("============================================");

if (passNum != testNum) {
    throw "FI analytics tests failed";
}
