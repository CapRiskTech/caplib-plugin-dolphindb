ok = t("CreateBondYieldCurveBuildSettings -> MTN handle/json",
    isHandleJson(cnyMtnBuildSettings, "CNY_MTN_AAA_SPRD_STD_CFETS_BUILD_SETTINGS") &&
    hasJsonField(cnyMtnBuildSettings[1], "curve_name") &&
    hasJsonField(cnyMtnBuildSettings[1], "curve_type"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("BuildBondYieldCurve -> [CNY_TREAS_STD_CFETS, json]",
    isHandleJson(cnyTreasStdCfets, "CNY_TREAS_STD_CFETS") &&
    hasJsonField(cnyTreasStdCfets[1], "curve"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("BuildBondCreditSpreadCurve -> [CNY_MTN_AAA_SPRD_STD_CFETS, json]",
    isHandleJson(cnyMtnAaaSprdStdCfets, "CNY_MTN_AAA_SPRD_STD_CFETS") &&
    hasJsonField(cnyMtnAaaSprdStdCfets[1], "curve"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

print("");
print("--- Test 3: FI market/risk factories ---");
ok = t("CreateFiMktDataSet -> [FI_MKT, json]",
    isHandleJson(fiMktData, "FI_MKT") &&
    hasJsonField(fiMktData[1], "discount_curve") &&
    hasJsonField(fiMktData[1], "spread_curve"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CreateBondMktDataSet -> [FI_BOND_MKT, json]",
    isHandleJson(bondMktData, "FI_BOND_MKT") &&
    hasJsonField(bondMktData[1], "discount_curve") &&
    hasJsonField(bondMktData[1], "spread_curve"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CreateFiRiskSettings -> [FI_RISK, json]",
