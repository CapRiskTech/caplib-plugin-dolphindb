testNum = 0;
passNum = 0;

def t(name, cond) {
    if (cond) { print("  PASS: " + name); }
    else      { print("  FAIL: " + name); }
    return cond;
}

def isHandleJson(result, expectedHandle) {
    return strpos(typestr(result), "STRING VECTOR") >= 0 &&
        size(result) == 2 && result[0] == expectedHandle && strlen(result[1]) > 0;
}

def isJsonOnly(result) {
    return size(result) == 2 && result[0] == "" && strlen(result[1]) > 0;
}

def hasJsonField(json, fieldName) {
    return strpos(json, "\"" + fieldName + "\"") >= 0;
}

def isPricingResultsJson(result, expectedHandle) {
    return isHandleJson(result, expectedHandle) &&
        hasJsonField(result[1], "present_value") &&
        hasJsonField(result[1], "cash_value") &&
        hasJsonField(result[1], "currency");
}

def createStdFixedBondTemplate(instName, maturity, currency, calendarName, asOfDate) {
    return caplib::CreateVanillaBondTemplate(
        instName, "FIXED_COUPON_BOND",
        asOfDate, 1, asOfDate, maturity,
        0.0, currency, 100.0,
        "ACT_365_FIXED", calendarName, "ANNUAL",
        "MODIFIED_FOLLOWING", "INITIAL", "LONG",
        0, "MODIFIED_FOLLOWING", "",
        "", "INVALID_FREQUENCY", "INVALID_BUSINESS_DAY_CONVENTION",
        "INVALID_DATE_GENERATION_MODE", -1,
        "0d", "", "INVALID_BUSINESS_DAY_CONVENTION", false,
        "CONST_NOTIONAL", 0.0, true);
}

def createStdZeroBondTemplate(instName, maturity, currency, calendarName, asOfDate) {
    return caplib::CreateVanillaBondTemplate(
        instName, "ZERO_COUPON_BOND",
        asOfDate, 1, asOfDate, maturity,
        0.0, currency, 100.0,
        "ACT_365_FIXED", calendarName, "ANNUAL",
        "MODIFIED_FOLLOWING", "INITIAL", "LONG",
        0, "MODIFIED_FOLLOWING", "",
        "", "INVALID_FREQUENCY", "INVALID_BUSINESS_DAY_CONVENTION",
        "INVALID_DATE_GENERATION_MODE", -1,
        "0d", "", "INVALID_BUSINESS_DAY_CONVENTION", false,
        "CONST_NOTIONAL", 0.0, true);
}

