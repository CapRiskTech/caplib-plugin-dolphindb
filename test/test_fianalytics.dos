ok = t("MTN AAA standard template ladder -> 12 handles",
    isHandleJson(cnyMtnAaaCpnA1m, "CNY_MTN_AAA_CPN_A_1M") &&
    isHandleJson(cnyMtnAaaCpnA5y, "CNY_MTN_AAA_CPN_A_5Y") &&
    isHandleJson(cnyMtnAaaCpnA9y, "CNY_MTN_AAA_CPN_A_9Y"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

ok = t("CreateVanillaBondTemplate -> CNY_TREAS_CPN_BOND_200014",
    isHandleJson(cnyTreasCpnBond200014Template, "CNY_TREAS_CPN_BOND_200014") &&
    hasJsonField(cnyTreasCpnBond200014Template[1], "instrument_name") &&
    hasJsonField(cnyTreasCpnBond200014Template[1], "leg_definition"));
testNum = testNum + 1; passNum = passNum + iif(ok, 1, 0);

print("");
print("--- Test 2: Bond par curve and build settings factories ---");
ok = t("CreateBondParCurve -> treasury CFETS JSON",
    isHandleJson(parCnyTreasStdCfets, cnyTreasStdCfetsName) &&
    hasJsonField(parCnyTreasStdCfets[1], "reference_date") &&
    hasJsonField(parCnyTreasStdCfets[1], "pillars") &&
    hasJsonField(parCnyTreasStdCfets[1], "name"));
